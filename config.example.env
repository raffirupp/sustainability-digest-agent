# ----------------------------------------------------------------------------
# Sustainability Regulation Digest – Configuration
# Copy to `.env` and fill in your values.
# Local: `set -a; source .env; set +a`
# GitHub Actions: store as Secrets / Variables (see README)
# ----------------------------------------------------------------------------

# OpenAI API key (required). Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Slack Incoming Webhook URL (required for posting).
# Create a Slack app -> enable "Incoming Webhooks" -> add a webhook for your channel.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# One or more EUR-Lex RSS feeds, comma-separated.
# Tip: start with a broad feed – OpenAI filters by your relevance criteria anyway.
# Browse predefined feeds: https://eur-lex.europa.eu/predefined-rss.html
# Build your own: EUR-Lex -> Expert search -> "Create RSS alert"
#
# Good starting feeds for sustainability/environment topics:
#   OJ L-series (binding legislation): https://eur-lex.europa.eu/OJ/EN/display-feed.rss?myRssId=L_series
#   Recent acts – environment:         https://eur-lex.europa.eu/predefined-rss.html (pick "Environment")
FEED_URLS=https://eur-lex.europa.eu/OJ/EN/display-feed.rss?myRssId=L_series

# Relevance criteria in plain language – the most important setting.
# Describe your industry, topics, and obligations in 2-4 sentences.
RELEVANCE_CRITERIA=Relevant for a German startup (17 employees, ~€3-4M revenue) manufacturing condoms and menstrual/period products. Main raw materials: organic cotton (GOTS-certified) from Tanzania and latex from regenerative agroforestry in Thailand. Priority topics: ESPR ecodesign requirements, Green Claims Directive, packaging and plastics regulations, CSRD/sustainability reporting for SMEs, EU supply chain due diligence, REACH chemicals restrictions (latex/cotton processing), EU Ecolabel for hygiene products, Medical Device Regulation (MDR), social and labour standards. Exclude: fisheries, automotive, agricultural subsidies, energy sector.

# Optional: OpenAI model. gpt-4o-mini is cheap and fast; gpt-4o for higher quality.
OPENAI_MODEL=gpt-4o-mini

# Optional: max documents processed per run (cost/flood protection)
MAX_ITEMS_PER_RUN=50

# Optional: post on the very first run? Default false = silent seed.
POST_ON_FIRST_RUN=false

# Optional: path to deduplication state file
STATE_FILE=state.json
